{
  "name": "project-mobile-javascript",
  "version": "0.0.4",
  "author": "Diogo Rangel <diodam.rangel@gmail.com>",
  "license": "MIT",
  "description": "Project to run WebdriverIO tests with Appium to test native applications on iOS and Android",
  "homepage": "https://github.com/diogorangel/project-mobile-javascript#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diogorangel/project-mobile-javascript.git"
  },
  "bugs": {
    "url": "https://github.com/diogorangel/project-mobile-javascript/issues"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "keywords": [
    "WebdriverIO",
    "WebDriver",
    "appium",
    "native app",
    "hybrid",
    "android",
    "ios"
  ],
  "type": "module",
  "scripts": {
    "test:android": "wdio run ./config/wdio.android.conf.js",
    "test:ios": "wdio run ./config/wdio.ios.conf.js",
    "android.app": "wdio run config/wdio.android.app.conf.ts",
    "android.browser": "wdio run config/wdio.android.browser.conf.ts",
    "ios.app": "wdio run config/wdio.ios.app.conf.ts",
    "ios.browser": "wdio run config/wdio.ios.browser.conf.ts",
    "android.browserstack.app": "wdio run config/browserstack/wdio.android.bs.app.conf.ts",
    "android.lt.browser.emulator": "wdio run config/lambdatest/wdio.android.emulator.browser.conf.ts",
    "android.lt.browser.realdevice": "wdio run config/lambdatest/wdio.android.realdevice.browser.conf.ts",
    "android.lt.app.realdevice": "wdio run config/lambdatest/wdio.android.realdevice.app.conf.ts",
    "android.sauce.emulators.app.eu": "REGION=eu wdio run config/saucelabs/wdio.android.emulators.app.conf.ts",
    "android.sauce.emulators.app.us": "wdio run config/saucelabs/wdio.android.emulators.app.conf.ts",
    "android.sauce.rdc.app.eu": "REGION=eu wdio run config/saucelabs/wdio.android.rdc.app.conf.ts",
    "android.sauce.rdc.app.us": "wdio run config/saucelabs/wdio.android.rdc.app.conf.ts",
    "android.testingbot.app": "wdio run config/testingbot/wdio.android.tb.app.conf.ts",
    "ios.lt.browser.simulator": "wdio run config/lambdatest/wdio.ios.simulator.browser.conf.ts",
    "ios.lt.browser.realdevice": "wdio run config/lambdatest/wdio.ios.realdevice.browser.conf.ts",
    "ios.sauce.simulators.app.eu": "REGION=eu wdio run config/saucelabs/wdio.ios.simulators.app.conf.ts",
    "ios.sauce.simulators.app.us": "wdio run config/saucelabs/wdio.ios.simulators.app.conf.ts",
    "browser": "wdio run config/wdio.browser.conf.ts",
    "test:local": "wdio run config/wdio.android.app.conf.ts",
    "lint": "eslint config tests",
    "appium:inspector": "npx start-appium-inspector",
    "wdio": "wdio run ./wdio.conf.js"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@wdio/appium-service": "^9.29.1",
    "@wdio/browserstack-service": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/sauce-service": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/testingbot-service": "^9.29.1",
    "@wdio/visual-service": "^10.1.0",
    "appium": "^3.1.2",
    "appium-inspector-plugin": "^2025.11.1",
    "appium-uiautomator2-driver": "^6.9.3",
    "appium-xcuitest-driver": "^10.13.2",
    "eslint-plugin-wdio": "^9.29.1",
    "expect-webdriverio": "^5.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wdio-lambdatest-service": "^4.0.1"
  },
  "dependencies": {
    "expo": "^57.0.4"
  }
}
